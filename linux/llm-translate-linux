#!/usr/bin/env bash
# Linux desktop helper for llm-translate.
# Bind this script to a desktop shortcut to translate or speak selected text.
set -euo pipefail

ACTION="translate-selection"
CLI_ARGS=()

usage() {
  cat <<'EOF'
llm-translate-linux - Linux desktop helper for llm-translate

USAGE
  llm-translate-linux [ACTION] [-- CLI_OPTIONS...]

ACTIONS
  translate-selection   Read selected text, translate it, show a dialog (default)
  speak-selection       Read selected text and speak it with a local TTS command
  test                  Translate "Hello, world!" to verify provider config
  diagnostics           Show CLI path, provider config, and available helpers

EXAMPLES
  llm-translate-linux translate-selection
  llm-translate-linux speak-selection
  llm-translate-linux test -- -p mymemory -t zh-CN

Bind the translate command in your desktop keyboard shortcuts, for example:
  /absolute/path/to/linux/llm-translate-linux translate-selection

NOTES
  X11 works best because PRIMARY selection can usually be read directly.
  Wayland compositors differ; install wl-clipboard plus wtype or ydotool, or
  bind the command in your compositor and allow it to send Ctrl+C.
EOF
}

die() {
  show_message "LLM Translate Failed" "$*"
  exit 1
}

have() {
  command -v "$1" >/dev/null 2>&1
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

resolve_script_path() {
  local target="$1" dir link
  case "$target" in
    /*) ;;
    *) target="$PWD/$target" ;;
  esac
  while [ -L "$target" ]; do
    dir="$(cd -P "$(dirname "$target")" >/dev/null 2>&1 && pwd)"
    link="$(readlink "$target")"
    case "$link" in
      /*) target="$link" ;;
      *) target="$dir/$link" ;;
    esac
  done
  dir="$(cd -P "$(dirname "$target")" >/dev/null 2>&1 && pwd)"
  printf '%s/%s\n' "$dir" "$(basename "$target")"
}

find_upward_cli() {
  local start_path="$1" path parent candidate
  path="$(cd -P "$start_path" >/dev/null 2>&1 && pwd)" || return 1

  while [ -n "$path" ]; do
    candidate="$path/bin/llm-translate"
    if [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi

    parent="$(dirname "$path")"
    [ "$parent" != "$path" ] || break
    path="$parent"
  done

  return 1
}

find_cli() {
  local script_path script_dir configured from_script from_cwd from_path

  configured="${LLM_TRANSLATE_CLI:-}"
  if [ -n "$configured" ] && [ -x "$configured" ]; then
    printf '%s\n' "$configured"
    return 0
  fi

  script_path="$(resolve_script_path "${BASH_SOURCE[0]}")"
  script_dir="$(dirname "$script_path")"
  if from_script="$(find_upward_cli "$script_dir")"; then
    printf '%s\n' "$from_script"
    return 0
  fi

  if from_cwd="$(find_upward_cli "$PWD")"; then
    printf '%s\n' "$from_cwd"
    return 0
  fi

  if from_path="$(command -v llm-translate 2>/dev/null)"; then
    printf '%s\n' "$from_path"
    return 0
  fi

  return 1
}

load_config_file() {
  local config_path="${XDG_CONFIG_HOME:-$HOME/.config}/llm-translate/env"
  local raw_line line key value separator

  [ -f "$config_path" ] || return 0

  while IFS= read -r raw_line || [ -n "$raw_line" ]; do
    line="$(trim "$raw_line")"
    [ -n "$line" ] || continue
    case "$line" in
      \#*) continue ;;
    esac

    separator="${line%%=*}"
    [ "$separator" != "$line" ] || continue
    key="$(trim "$separator")"
    value="$(trim "${line#*=}")"

    case "$value" in
      \"*\")
        [ "${value%\"}" != "$value" ] && value="${value#\"}" && value="${value%\"}"
        ;;
      \'*\')
        [ "${value%\'}" != "$value" ] && value="${value#\'}" && value="${value%\'}"
        ;;
    esac

    [[ "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || continue
    if [ -z "${!key+x}" ]; then
      export "$key=$value"
    fi
  done < "$config_path"
}

apply_defaults() {
  if [ -z "${LLM_TRANSLATE_PROVIDER+x}" ] && [ -z "${DEEPSEEK_API_KEY+x}" ]; then
    export LLM_TRANSLATE_PROVIDER="mymemory"
  fi
  if [ -z "${LLM_TRANSLATE_TARGET+x}" ]; then
    export LLM_TRANSLATE_TARGET="Simplified Chinese"
  fi
}

is_nonempty_text() {
  [ -n "$(trim "$1")" ]
}

read_primary_selection() {
  local output

  if [ -n "${WAYLAND_DISPLAY:-}" ] && have wl-paste; then
    if output="$(wl-paste --primary --no-newline 2>/dev/null)" && is_nonempty_text "$output"; then
      printf '%s' "$output"
      return 0
    fi
  fi

  if [ -n "${DISPLAY:-}" ] && have xclip; then
    if output="$(xclip -selection primary -o 2>/dev/null)" && is_nonempty_text "$output"; then
      printf '%s' "$output"
      return 0
    fi
  fi

  if [ -n "${DISPLAY:-}" ] && have xsel; then
    if output="$(xsel --primary --output 2>/dev/null)" && is_nonempty_text "$output"; then
      printf '%s' "$output"
      return 0
    fi
  fi

  return 1
}

read_clipboard() {
  local output

  if [ -n "${WAYLAND_DISPLAY:-}" ] && have wl-paste; then
    output="$(wl-paste --no-newline 2>/dev/null || true)"
    printf '%s' "$output"
    return 0
  fi

  if [ -n "${DISPLAY:-}" ] && have xclip; then
    output="$(xclip -selection clipboard -o 2>/dev/null || true)"
    printf '%s' "$output"
    return 0
  fi

  if [ -n "${DISPLAY:-}" ] && have xsel; then
    output="$(xsel --clipboard --output 2>/dev/null || true)"
    printf '%s' "$output"
    return 0
  fi

  return 1
}

write_clipboard() {
  local text="$1"

  if [ -n "${WAYLAND_DISPLAY:-}" ] && have wl-copy; then
    printf '%s' "$text" | wl-copy
    return 0
  fi

  if [ -n "${DISPLAY:-}" ] && have xclip; then
    printf '%s' "$text" | xclip -selection clipboard
    return 0
  fi

  if [ -n "${DISPLAY:-}" ] && have xsel; then
    printf '%s' "$text" | xsel --clipboard --input
    return 0
  fi

  return 1
}

clear_clipboard() {
  write_clipboard "" >/dev/null 2>&1 || true
}

post_copy_shortcut() {
  if [ -n "${DISPLAY:-}" ] && have xdotool; then
    xdotool key --clearmodifiers ctrl+c
    return 0
  fi

  if [ -n "${WAYLAND_DISPLAY:-}" ] && have wtype; then
    wtype -M ctrl c -m ctrl
    return 0
  fi

  if have ydotool; then
    ydotool key 29:1 46:1 46:0 29:0
    return 0
  fi

  return 1
}

read_selection_via_copy() {
  local old_clipboard had_clipboard selected attempt

  old_clipboard="$(read_clipboard || true)"
  had_clipboard=0
  [ -n "$old_clipboard" ] && had_clipboard=1

  clear_clipboard
  post_copy_shortcut || return 1

  selected=""
  attempt=0
  while [ "$attempt" -lt 8 ]; do
    attempt=$((attempt + 1))
    sleep 0.08
    selected="$(read_clipboard || true)"
    if is_nonempty_text "$selected"; then
      break
    fi
  done

  if [ "$had_clipboard" -eq 1 ]; then
    write_clipboard "$old_clipboard" >/dev/null 2>&1 || true
  else
    clear_clipboard
  fi

  is_nonempty_text "$selected" || return 1
  printf '%s' "$selected"
}

read_selected_text() {
  local text

  if text="$(read_primary_selection)"; then
    printf '%s' "$text"
    return 0
  fi

  if text="$(read_selection_via_copy)"; then
    printf '%s' "$text"
    return 0
  fi

  return 1
}

show_message() {
  local title="$1" body="$2" tmp_file

  if have zenity; then
    printf '%s' "$body" | zenity --text-info --title="$title" --width=680 --height=460 2>/dev/null || true
    return 0
  fi

  if have kdialog; then
    tmp_file="$(mktemp)"
    printf '%s' "$body" > "$tmp_file"
    kdialog --title "$title" --textbox "$tmp_file" 680 460 2>/dev/null || true
    rm -f "$tmp_file"
    return 0
  fi

  if have yad; then
    printf '%s' "$body" | yad --text-info --title="$title" --width=680 --height=460 2>/dev/null || true
    return 0
  fi

  if have xmessage && [ -n "${DISPLAY:-}" ]; then
    printf '%s' "$body" | xmessage -file - -title "$title" 2>/dev/null || true
    return 0
  fi

  printf '%s\n\n%s\n' "$title" "$body"
}

notify_status() {
  local title="$1" body="$2"

  if have notify-send; then
    notify-send "$title" "$body" >/dev/null 2>&1 || true
  fi
}

run_translation() {
  local cli_path="$1" text="$2" output err_file err exit_code

  err_file="$(mktemp)"
  if output="$(printf '%s' "$text" | "$cli_path" "${CLI_ARGS[@]}" 2>"$err_file")"; then
    rm -f "$err_file"
    printf '%s' "$output"
    return 0
  fi

  exit_code=$?
  err="$(cat "$err_file")"
  rm -f "$err_file"
  printf 'CLI failed with exit code %s.\n\nstderr:\n%s' "$exit_code" "${err:-"(empty)"}"
  return "$exit_code"
}

speak_text() {
  local text="$1"

  if have spd-say; then
    spd-say "$text"
    return 0
  fi

  if have espeak-ng; then
    espeak-ng "$text"
    return 0
  fi

  if have espeak; then
    espeak "$text"
    return 0
  fi

  return 1
}

diagnostics() {
  local cli_path="$1" config_path="${XDG_CONFIG_HOME:-$HOME/.config}/llm-translate/env"
  cat <<EOF
CLI: $cli_path
Provider: ${LLM_TRANSLATE_PROVIDER:-"(unset)"}
Model: ${LLM_TRANSLATE_MODEL:-"(provider default)"}
Target: ${LLM_TRANSLATE_TARGET:-"(unset)"}
Config: $config_path exists: $([ -f "$config_path" ] && printf yes || printf no)
Session: XDG_SESSION_TYPE=${XDG_SESSION_TYPE:-"(unset)"} DISPLAY=${DISPLAY:-"(unset)"} WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-"(unset)"}

Helpers:
  dialog: $(have zenity && printf zenity || have kdialog && printf kdialog || have yad && printf yad || have xmessage && printf xmessage || printf none)
  clipboard: $(have wl-paste && printf wl-clipboard || have xclip && printf xclip || have xsel && printf xsel || printf none)
  copy shortcut: $(have xdotool && printf xdotool || have wtype && printf wtype || have ydotool && printf ydotool || printf none)
  speech: $(have spd-say && printf spd-say || have espeak-ng && printf espeak-ng || have espeak && printf espeak || printf none)
EOF
}

parse_args() {
  case "${1:-}" in
    translate-selection|speak-selection|test|diagnostics)
      ACTION="$1"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
  esac

  if [ "${1:-}" = "--" ]; then
    shift
  fi
  CLI_ARGS=("$@")
}

main() {
  local cli_path text translated message

  parse_args "$@"
  load_config_file
  apply_defaults

  cli_path="$(find_cli)" || die "Cannot find bin/llm-translate. Run from the repository checkout or set LLM_TRANSLATE_CLI."

  case "$ACTION" in
    translate-selection)
      text="$(read_selected_text)" || die "No selected text was found. Select text first, then trigger translation."
      notify_status "LLM Translate" "Translating selected text..."
      if translated="$(run_translation "$cli_path" "$text")"; then
        show_message "Translation" "${translated:-"(empty result)"}"
      else
        message="$translated"
        show_message "Translation Failed" "$message"
        return 1
      fi
      ;;
    speak-selection)
      text="$(read_selected_text)" || die "No selected text was found. Select text first, then trigger speech."
      speak_text "$text" || die "No speech command found. Install speech-dispatcher, espeak-ng, or espeak."
      ;;
    test)
      if translated="$(run_translation "$cli_path" "Hello, world!")"; then
        show_message "Translation Test" "${translated:-"(empty result)"}"
      else
        message="$translated"
        show_message "Translation Test Failed" "$message"
        return 1
      fi
      ;;
    diagnostics)
      show_message "Diagnostics" "$(diagnostics "$cli_path")"
      ;;
    *)
      usage
      return 2
      ;;
  esac
}

main "$@"
