#!/usr/bin/env bash
# llm-translate — translate stdin via an LLM provider
# https://github.com/MarsDoge/llm-translate
set -euo pipefail

VERSION="0.1.0"

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
LIB_DIR="${LLM_TRANSLATE_LIB:-$SCRIPT_DIR/../lib}"

PROVIDER="${LLM_TRANSLATE_PROVIDER:-deepseek}"
MODEL="${LLM_TRANSLATE_MODEL:-}"
TARGET="${LLM_TRANSLATE_TARGET:-Simplified Chinese}"
SOURCE_LANG="${LLM_TRANSLATE_SOURCE:-auto}"
TEMPERATURE="${LLM_TRANSLATE_TEMPERATURE:-0.2}"
TASK="${LLM_TRANSLATE_TASK:-translate}"
STREAM="${LLM_TRANSLATE_STREAM:-0}"

usage() {
  cat <<EOF
llm-translate $VERSION — translate stdin via an LLM provider

USAGE
  llm-translate [OPTIONS] < input.txt
  echo "hello world" | llm-translate -t "French"

OPTIONS
  -p, --provider NAME     Provider: deepseek | openai | claude | ollama | aliyun-codingplan | mymemory
                          (default: \$LLM_TRANSLATE_PROVIDER or deepseek)
  -m, --model NAME        Model name (provider-specific default; unused for mymemory)
  -t, --target LANG       Target language. Accepts natural name ("Chinese")
                          or ISO code ("zh-CN"). Non-LLM providers need ISO.
                          (default: "Simplified Chinese")
  -s, --source LANG       Source language hint (default: auto)
      --task WHAT         translate (default) | optimize | bugfix | mindmap
                          optimize rewrites the input as cleaner code; bugfix
                          hunts for common programmer bugs (boundaries, null
                          handling, off-by-one, wrong operator, etc) and
                          patches with inline FIX: comments; mindmap reads a
                          symbol + its ctags/cscope dependencies from stdin
                          and emits a Mermaid flowchart. All three require an
                          LLM provider (not mymemory).
      --temperature N     Sampling temperature, LLM providers only (default: 0.2)
      --stream            Stream output tokens as they arrive (LLM providers
                          only; mymemory does not stream)
      --list-providers    List supported providers and exit
  -v, --version           Print version
  -h, --help              Show this help

ENVIRONMENT
  LLM_TRANSLATE_PROVIDER  Default provider
  LLM_TRANSLATE_MODEL     Default model
  LLM_TRANSLATE_TARGET    Default target language
  DEEPSEEK_API_KEY        Key for the deepseek provider
  OPENAI_API_KEY          Key for the openai provider
  ANTHROPIC_API_KEY       Key for the claude provider
  ALIYUN_CODING_PLAN_API_KEY
                          Key for the aliyun-codingplan provider (Aliyun Coding Plan)
  OLLAMA_HOST             Base URL for ollama (default http://localhost:11434)
  MYMEMORY_EMAIL          Optional email for mymemory; raises daily quota

EXAMPLES
  echo "Hello, world!" | llm-translate -t "Chinese"
  llm-translate -p openai -m gpt-4o-mini < README.md
  llm-translate -p aliyun-codingplan -m qwen3.5-plus --task optimize < messy.py
  llm-translate -p ollama -m qwen2.5:7b -t English < notes.txt
  echo "Hello" | llm-translate -p mymemory -t zh-CN     # no API key needed
  llm-translate --task optimize < messy.py              # rewrite as cleaner Python
  llm-translate --task bugfix   < buggy.go              # fix logic bugs, mark with FIX:
  llm-translate --task mindmap  < ctags-dump.txt        # Mermaid graph of a symbol's deps
EOF
}

list_providers() {
  find "$LIB_DIR/providers" -maxdepth 1 -name '*.sh' -printf '%f\n' 2>/dev/null \
    | sed 's/\.sh$//' | sort
}

die() { echo "llm-translate: $*" >&2; exit 1; }

# --- arg parsing -----------------------------------------------------------
while [ $# -gt 0 ]; do
  case "$1" in
    -p|--provider)     PROVIDER="$2"; shift 2 ;;
    -m|--model)        MODEL="$2"; shift 2 ;;
    -t|--target)       TARGET="$2"; shift 2 ;;
    -s|--source)       SOURCE_LANG="$2"; shift 2 ;;
    --task)            TASK="$2"; shift 2 ;;
    --temperature)     TEMPERATURE="$2"; shift 2 ;;
    --stream)          STREAM=1; shift ;;
    --no-stream)       STREAM=0; shift ;;
    --list-providers)  list_providers; exit 0 ;;
    -v|--version)      echo "$VERSION"; exit 0 ;;
    -h|--help)         usage; exit 0 ;;
    --)                shift; break ;;
    -*)                die "unknown option: $1 (try --help)" ;;
    *)                 die "unexpected argument: $1" ;;
  esac
done

# --- deps ------------------------------------------------------------------
command -v jq   >/dev/null 2>&1 || die "jq is required"
command -v curl >/dev/null 2>&1 || die "curl is required"

PROVIDER_SCRIPT="$LIB_DIR/providers/$PROVIDER.sh"
[ -f "$PROVIDER_SCRIPT" ] || die "unknown provider: $PROVIDER (see --list-providers)"

# Streaming is opt-in per provider. A provider declares support with a
# header comment: "# llm-translate-stream: yes". Absent or "no" → reject.
if [ "$STREAM" = "1" ]; then
  if ! grep -qE '^# llm-translate-stream:[[:space:]]*yes[[:space:]]*$' "$PROVIDER_SCRIPT"; then
    die "--stream is not supported by provider '$PROVIDER'"
  fi
fi

# --- read input ------------------------------------------------------------
if [ -t 0 ]; then
  die "no input on stdin; pipe text or redirect a file"
fi
INPUT="$(cat)"
[ -n "$INPUT" ] || die "empty input"

# --- build prompt ----------------------------------------------------------
case "$TASK" in
  translate)
    if [ "$SOURCE_LANG" = "auto" ]; then
      SYSTEM_PROMPT="You are a professional translator. Translate the user's text into ${TARGET}. Preserve code blocks, commands, file paths, identifiers, error codes, register names, and function names. Keep formatting (markdown, indentation, newlines) clean and unchanged. Output only the translated text, with no preamble or commentary."
    else
      SYSTEM_PROMPT="You are a professional translator. Translate the user's text from ${SOURCE_LANG} into ${TARGET}. Preserve code blocks, commands, file paths, identifiers, error codes, register names, and function names. Keep formatting clean. Output only the translated text, with no preamble or commentary."
    fi
    ;;
  optimize)
    case "$PROVIDER" in
      mymemory) die "--task optimize requires an LLM provider (mymemory is translation-only)" ;;
    esac
    SYSTEM_PROMPT="You are a senior software engineer. Rewrite the user's code snippet to be cleaner, more idiomatic, and more efficient while preserving observable behavior.

Rules:
- Output ONLY the optimized code. No prose, no explanations, no markdown fences, no leading or trailing blank lines beyond what the input had.
- Detect the programming language from the input and keep the same language and file-level conventions.
- Preserve the original indentation style (tabs vs spaces, indent width).
- Keep public APIs, function names, and external behavior identical unless the change fixes a clear bug; in that case still match the original signature.
- Prefer readable, idiomatic patterns over clever ones. Eliminate dead code, unused variables, and redundant comments.
- Do not add framing text, headings, or commit-message-like summaries.
- If the snippet is already optimal, return it unchanged."
    ;;
  bugfix)
    case "$PROVIDER" in
      mymemory) die "--task bugfix requires an LLM provider (mymemory is translation-only)" ;;
    esac
    SYSTEM_PROMPT="You are a senior software engineer reviewing the user's code snippet for common programmer bugs — the kind of defects that slip past code review because they only surface at edge cases. Your job is to identify clear bugs and patch them with MINIMAL changes, leaving everything else byte-identical.

Focus on these defect patterns:

Boundary and edge conditions:
- Off-by-one errors: '<' vs '<=', inclusive vs exclusive ranges, first/last index
- Empty collections: indexing without length check, empty-iteration assumptions
- Zero and negative boundaries: division or modulo by zero, negative indices, unsigned underflow
- Integer overflow in bounded-int languages (C, Go, Rust, Java, C#)
- Floating-point equality compared with '=='
- Unicode or multi-byte strings: byte length counted as character length, indexing into a codepoint midpoint
- Date and time boundaries: month-end, year-end, leap year, DST, timezone confusion

Null, empty, uninitialized:
- Null / None / nil / undefined dereference, unchecked return value
- Use before initialization, partial initialization
- Optional or Maybe unwrapped without check

Wrong-thing bugs:
- Swapped arguments of the same type ('copy(dst, src)' reversed)
- Wrong variable used ('x' where 'y' was meant in a pair)
- Wrong operator ('&' vs '&&', '=' vs '==', '|' vs '||')
- Inverted branch ('if !cond' where 'if cond' was meant)
- Missing 'break' causing fallthrough, missing 'return'

Concurrency and state:
- Iterator invalidation (mutating a container while iterating)
- Race conditions, TOCTOU
- Shared mutable state or aliased containers
- Missing lock or lock released too early

Resource and error handling:
- Missing cleanup (close, unlock, free, unsubscribe)
- Resource leak on error path, double-free, use-after-free
- Error silently swallowed, exception suppressed, return code ignored
- Partial write or short read not retried

Rules:
- Output ONLY code. No prose outside the code, no explanations, no markdown fences, no headers.
- Detect the programming language from the input and keep the same language.
- Do NOT change style, naming, formatting, indentation, or refactor working code. Only patch real bugs.
- Preserve public APIs, function signatures, and all non-defective surrounding lines exactly.
- For every line you modify or add, insert a comment on its OWN LINE immediately above the change, in the language's native comment style. Format: 'FIX: <one-line reason>'. Example:
      // FIX: guard against b == 0 to prevent division by zero
      if b == 0 { return 0 }
- Bias STRONGLY toward returning the input unchanged. Most snippets contain no real bugs. Only patch a line if you would stake your professional reputation on it being a genuine defect.
- Never add TODO, NOTE, explanatory, or stylistic comments beyond the FIX: markers.
- If you see no bugs, return the input UNCHANGED."
    ;;
  mindmap)
    case "$PROVIDER" in
      mymemory) die "--task mindmap requires an LLM provider (mymemory is translation-only)" ;;
    esac
    SYSTEM_PROMPT="You are a software-architecture visualizer. The user will supply a block of structured context about ONE symbol (function, type, macro, or variable): its name, a definition line if known, and a list of ctags / cscope / grep hits describing where it is referenced and what it touches.

Your job: emit a single Mermaid flowchart that puts the symbol at the centre, its callees / dependencies downstream, and its callers / usage sites upstream.

Rules:
- Output ONLY the Mermaid source. No prose, no markdown fences, no preamble, no trailing explanation.
- First line MUST be 'graph TD' (or 'graph LR' if you judge a horizontal layout reads better).
- The target symbol is the centre node. Give it a stable id and a bracketed label, e.g. 'center[\"parse_args()\"]'. Make it visually distinct with 'style center fill:#ffd,stroke:#a80,stroke-width:2px'.
- One node per distinct caller and per distinct callee. Use identifiers that are valid Mermaid ids (alphanumeric, underscore); keep display labels human-friendly in brackets.
- Edges: 'caller_id --> center' for callers, 'center --> callee_id' for callees. If the evidence shows a data/type dependency rather than a call, label the edge: 'center -->|uses| type_id'.
- If multiple references come from the same file, group them with 'subgraph filename.c ... end'.
- Cap the diagram at ~20 nodes. If more exist, add one node labelled '(N more callers)' or '(N more callees)' with an edge to/from the centre.
- If the context is empty or contains no recognisable symbol, emit:
      graph TD
          unknown[\"(no evidence)\"]
- Do NOT invent relationships. If you only have a definition and no references, emit the centre node alone with a short 'defined in' label."
    ;;
  *)
    die "unknown --task: $TASK (want translate, optimize, bugfix, or mindmap)"
    ;;
esac

# --- language-code normalization (for non-LLM providers) -------------------
# Maps natural-language names and common variants to BCP 47-ish codes
# (mymemory-style). Unknown input is echoed back unchanged so ISO codes
# passed directly by the user still work. LLM providers ignore this and
# use the raw $TARGET / $SOURCE_LANG.
normalize_lang_code() {
  local lower
  lower="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
  case "$lower" in
    zh|zh-cn|"simplified chinese"|chinese|中文|简体中文) echo "zh-CN" ;;
    zh-tw|"traditional chinese"|繁体中文)              echo "zh-TW" ;;
    en|en-us|en-gb|english|英语|英文)                   echo "en-US" ;;
    ja|ja-jp|japanese|日语|日本語)                       echo "ja-JP" ;;
    ko|ko-kr|korean|韩语|한국어)                         echo "ko-KR" ;;
    fr|fr-fr|french|法语)                              echo "fr-FR" ;;
    de|de-de|german|德语)                              echo "de-DE" ;;
    es|es-es|spanish|西班牙语)                          echo "es-ES" ;;
    ru|ru-ru|russian|俄语)                             echo "ru-RU" ;;
    it|it-it|italian|意大利语)                          echo "it-IT" ;;
    pt|pt-pt|portuguese|葡萄牙语)                       echo "pt-PT" ;;
    ar|ar-sa|arabic|阿拉伯语)                           echo "ar-SA" ;;
    auto)                                             echo "auto" ;;
    *)                                                echo "$1" ;;
  esac
}

LLM_TRANSLATE_TARGET_CODE="$(normalize_lang_code "$TARGET")"
LLM_TRANSLATE_SOURCE_CODE="$(normalize_lang_code "$SOURCE_LANG")"

export LLM_TRANSLATE_INPUT="$INPUT"
export LLM_TRANSLATE_SYSTEM="$SYSTEM_PROMPT"
export LLM_TRANSLATE_MODEL="$MODEL"
export LLM_TRANSLATE_TEMPERATURE="$TEMPERATURE"
export LLM_TRANSLATE_TARGET_CODE
export LLM_TRANSLATE_SOURCE_CODE
export LLM_TRANSLATE_TASK="$TASK"
export LLM_TRANSLATE_STREAM="$STREAM"

# --- dispatch --------------------------------------------------------------
exec bash "$PROVIDER_SCRIPT"
